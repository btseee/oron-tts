{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Smoke Test (synthetic)",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/scripts/test_pipeline.py",
            "args": [],
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}",
            "env": {
                "PYTHONPATH": "${workspaceFolder}"
            }
        },
        {
            "name": "Smoke Test + HF",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/scripts/test_pipeline.py",
            "args": ["--hf"],
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}",
            "env": {
                "PYTHONPATH": "${workspaceFolder}"
            }
        },
        {
            "name": "Prepare Dataset",
            "type": "debugpy",
            "request": "launch",
            "module": "scripts.prepare",
            "args": [
                "--output-dir", "data/processed",
                "--dataset", "all",
                "--max-samples", "100"
            ],
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}",
            "env": {
                "PYTHONPATH": "${workspaceFolder}"
            }
        },
        {
            "name": "Train Local (HF dataset)",
            "type": "debugpy",
            "request": "launch",
            "module": "scripts.train",
            "args": [
                "--config", "configs/local.yaml",
                "--dataset", "btsee/mbspeech_mn",
                "--log-dir", "output/logs",
                "--checkpoint-dir", "output/checkpoints"
            ],
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}",
            "env": {
                "PYTHONPATH": "${workspaceFolder}",
                "CUDA_VISIBLE_DEVICES": "0",
                "WANDB_PROJECT": "oron-tts"
            }
        },
        {
            "name": "Train Local (local data)",
            "type": "debugpy",
            "request": "launch",
            "module": "scripts.train",
            "args": [
                "--config", "configs/local.yaml",
                "--from-local",
                "--data-dir", "data/processed",
                "--log-dir", "output/logs",
                "--checkpoint-dir", "output/checkpoints"
            ],
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}",
            "env": {
                "PYTHONPATH": "${workspaceFolder}",
                "WANDB_PROJECT": "oron-tts"
            }
        },
        {
            "name": "Inference",
            "type": "debugpy",
            "request": "launch",
            "module": "scripts.infer",
            "args": [
                "--checkpoint", "output/checkpoints/f5tts_best.pt",
                "--text", "Сайн байна уу",
                "--lang", "mn",
                "--output", "output.wav"
            ],
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}",
            "env": {
                "PYTHONPATH": "${workspaceFolder}"
            }
        },
        {
            "name": "Debug Current File",
            "type": "debugpy",
            "request": "launch",
            "program": "${file}",
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}",
            "env": {
                "PYTHONPATH": "${workspaceFolder}"
            }
        }
    ]
}
