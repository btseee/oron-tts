{
    "version": "2.0.0",
    "tasks": [
        // ── Setup ──────────────────────────────────────────────────────────────
        {
            "label": "Setup: Create venv (Python 3.12)",
            "type": "shell",
            "command": "py -3.12 -m venv .venv",
            "options": { "cwd": "${workspaceFolder}" },
            "group": "build",
            "problemMatcher": []
        },
        {
            "label": "Setup: Install dependencies",
            "type": "shell",
            "command": ".venv/Scripts/pip install -e '.[dev]'",
            "options": { "cwd": "${workspaceFolder}" },
            "group": "build",
            "problemMatcher": []
        },
        {
            "label": "Setup: wandb login",
            "type": "shell",
            "command": ".venv/Scripts/python -m wandb login",
            "options": { "cwd": "${workspaceFolder}" },
            "group": "none",
            "problemMatcher": []
        },
        // ── Test ───────────────────────────────────────────────────────────────
        {
            "label": "Test: Smoke test (synthetic)",
            "type": "shell",
            "command": ".venv/Scripts/python scripts/test_pipeline.py",
            "options": { "cwd": "${workspaceFolder}" },
            "group": "test",
            "problemMatcher": []
        },
        {
            "label": "Test: Smoke test + HF dataset",
            "type": "shell",
            "command": ".venv/Scripts/python scripts/test_pipeline.py --hf",
            "options": { "cwd": "${workspaceFolder}" },
            "group": "test",
            "problemMatcher": []
        },
        // ── Quality ────────────────────────────────────────────────────────────
        {
            "label": "Lint (Ruff)",
            "type": "shell",
            "command": ".venv/Scripts/python -m ruff check src/ scripts/",
            "options": { "cwd": "${workspaceFolder}" },
            "group": "test",
            "problemMatcher": {
                "owner": "ruff",
                "fileLocation": ["relative", "${workspaceFolder}"],
                "pattern": {
                    "regexp": "^(.+):(\\d+):(\\d+): (\\w+) (.+)$",
                    "file": 1,
                    "line": 2,
                    "column": 3,
                    "code": 4,
                    "message": 5
                }
            }
        },
        {
            "label": "Format (Ruff + isort)",
            "type": "shell",
            "command": ".venv/Scripts/python -m ruff format src/ scripts/ ; .venv/Scripts/isort src/ scripts/",
            "options": { "cwd": "${workspaceFolder}" },
            "group": "build",
            "problemMatcher": []
        },
        // ── Training ───────────────────────────────────────────────────────────
        {
            "label": "Train: HF dataset (local config)",
            "type": "shell",
            "command": ".venv/Scripts/python scripts/train.py --config configs/local.yaml --dataset btsee/mbspeech_mn",
            "options": { "cwd": "${workspaceFolder}" },
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "isBackground": true,
            "problemMatcher": []
        },
        {
            "label": "Train: local data (local config)",
            "type": "shell",
            "command": ".venv/Scripts/python scripts/train.py --config configs/local.yaml --from-local --data-dir data/processed",
            "options": { "cwd": "${workspaceFolder}" },
            "group": "build",
            "isBackground": true,
            "problemMatcher": []
        },
        // ── Utilities ──────────────────────────────────────────────────────────
        {
            "label": "Clean build artifacts",
            "type": "shell",
            "command": "Get-ChildItem -Recurse -Directory -Filter '__pycache__' | Remove-Item -Recurse -Force -ErrorAction SilentlyContinue ; Get-ChildItem -Recurse -Directory -Filter '*.egg-info' | Remove-Item -Recurse -Force -ErrorAction SilentlyContinue ; Remove-Item -Recurse -Force -ErrorAction SilentlyContinue .ruff_cache, build, dist",
            "options": { "cwd": "${workspaceFolder}" },
            "group": "build",
            "problemMatcher": []
        }
    ]
}
